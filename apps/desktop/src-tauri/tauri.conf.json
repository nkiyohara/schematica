{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Schematica",
  "version": "../../../package.json",
  "identifier": "dev.schematica.editor",
  "build": {
    "beforeDevCommand": "corepack pnpm dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Schematica",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost; font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Schema-driven YAML, JSON, and TOML config editor",
    "longDescription": "Schematica is a fast schema-driven config editor for YAML, JSON, and TOML with a shared CLI and desktop app.",
    "fileAssociations": [
      {
        "ext": ["yaml", "yml"],
        "name": "YAML configuration",
        "description": "YAML configuration file",
        "mimeType": "application/yaml",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": ["json"],
        "name": "JSON configuration",
        "description": "JSON configuration file",
        "mimeType": "application/json",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": ["toml"],
        "name": "TOML configuration",
        "description": "TOML configuration file",
        "mimeType": "application/toml",
        "role": "Editor",
        "rank": "Default"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
