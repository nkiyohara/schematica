  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build",
    "build:web": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json && vitest run && vite build && node scripts/check-dist-assets.mjs",
    "check:dist": "vite build && node scripts/check-dist-assets.mjs",
    "dev": "tauri dev",
    "dev:web": "vite --host 127.0.0.1 --port 1420",
